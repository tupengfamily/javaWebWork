# ============================================================
# 小说数据看板 - 环境变量示例
# 复制为 .env 后修改实际值
# copy .env.example .env    (Windows)
# cp .env.example .env       (Linux/macOS)
# ============================================================

# MySQL
# 注意: 如果本机装了 MySQL 占 3306,改为 3307 避免端口冲突
MYSQL_ROOT_PASSWORD=root123
MYSQL_USER=novel
MYSQL_PASSWORD=novel123
MYSQL_PORT=3307

# 端口
BACKEND_PORT=8080
FRONTEND_PORT=80

# JWT (生产环境必须改为随机 32 字节以上字符串)
# 生成方式: powershell -Command "[Convert]::ToHexString((New-Object System.Security.Cryptography.RNGCryptoServiceProvider).GetBytes(32))"
JWT_SECRET=please-change-me-in-production-32bytes-min
JWT_EXPIRE_HOURS=24

# 时区
TZ=Asia/Shanghai
